{
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(git push * --force*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "env FORCE_COLOR=3 npx -y ccstatusline@latest",
    "padding": 0
  },
  "customInstructions": "Always test changes after implementing them.",
  "attribution": {
    "commit": "",
    "pr": ""
  }
}