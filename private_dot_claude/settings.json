{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi apply --dry-run *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(git push * --force*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "env FORCE_COLOR=3 npx -y ccstatusline@latest",
    "padding": 0
  },
  "customInstructions": "Always test changes after implementing them.",
  "attribution": {
    "commit": "",
    "pr": ""
  }
}