# tpm plugin installation
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'hallazzang/tmux-reset'
set -g @plugin 'catppuccin/tmux'
set -g @plugin 'sainnhe/tmux-fzf'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugin/tmux-continuum'
set -g @plugin 'pschmitt/tmux-ssh-split'


# Bell monitoring - highlights windows when Claude Code finishes
set -g monitor-bell on
set -g visual-bell off
set -g bell-action other

set -g default-terminal "screen-256color"
set -g base-index 1
setw -g pane-base-index 1
set -g mouse on
setw -g automatic-rename on
set -g @continuum-restore 'on'
set-option -g allow-passthrough on

{{ if eq .chezmoi.os "darwin" -}}
# rebind the prefix to C-SPACE on macOS
unbind C-b
set -g prefix C-Space
bind-key C-Space send-prefix
{{ else -}}
# keep default C-b prefix on Linux
{{ end -}}

# Shargeek palette
# yellow (#E8B830) accent, gunmetal (#3A3D42) frame, deep-black (#111113) bg

# pane borders
set -g pane-border-lines heavy
set -g pane-border-status bottom
set -g pane-border-format " #{b:pane_current_path} #{?#{==:#{pane_current_command},ssh},󰣀 ,}#{@claude_status}"
set -g pane-active-border-style "fg=#E8B830"
set -g pane-border-style "fg=#5C4A1A"
set -g @catppuccin_pane_border_style "fg=#5C4A1A"
set -g @catppuccin_pane_active_border_style "fg=#E8B830"
set -g @catppuccin_pane_status_enabled "off"

# status bar
set -g status-position bottom
set -g status-justify centre
set -g status-left-length 050
set -g status-right-length 080
set -g status-style "bg=#1C1D1F"
set-option -g status-interval 1
set-option -g status-left "#[fg=#E8B830,bg=#1C1D1F,bold] #S "
set-option -g status-right "#{?SSH_CONNECTION,#[fg=#E8B830] 󰣀 #[fg=#8A8D93]#{=20:SSH_CONNECTION} ,}#[fg=#8A8D93]%Y-%m-%d #[fg=#E8E8EA]%H:%M:%S "

# catppuccin window styling – Shargeek colors, rounded separators
set -g @catppuccin_window_status_style "rounded"
set -g @catppuccin_window_number_color "#3A3D42"
set -g @catppuccin_window_text_color "#2A2D31"
set -g @catppuccin_window_text " #W #(~/.config/tmux/scripts/aggregate-claude-status.sh '#S:#I')"
set -g @catppuccin_window_current_number_color "#E8B830"
set -g @catppuccin_window_current_text_color "#2A2D31"
set -g @catppuccin_window_current_text " #W #(~/.config/tmux/scripts/aggregate-claude-status.sh '#S:#I')"

# reload config shortcut
unbind r
bind r source-file ~/.config/tmux/tmux.conf

# SSH split configuration - preserve both SSH sessions and working directories
set-option -g @ssh-split-keep-cwd "true"           # Preserve local working directory
set-option -g @ssh-split-keep-remote-cwd "true"    # Preserve remote working directory
set-option -g @ssh-split-strip-cmd "true"          # Clean SSH commands
set-option -g @ssh-split-no-shell "false"          # Keep shell sessions

# Unbind default split keys
unbind '"'
unbind %

# Rebind default keys to use SSH-aware splits with directory preservation
bind '"' if-shell '[ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]' \
    'run-shell "~/.tmux/plugins/tmux-ssh-split/scripts/tmux-ssh-split -v"' \
    'split-window -c "#{pane_current_path}"'
bind % if-shell '[ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]' \
    'run-shell "~/.tmux/plugins/tmux-ssh-split/scripts/tmux-ssh-split -h"' \
    'split-window -h -c "#{pane_current_path}"'

# Additional bindings for SSH-aware splits
set-option -g @ssh-split-h-key "|"                 # Alternative horizontal split
set-option -g @ssh-split-v-key "-"                 # Alternative vertical split

# dynamic pane resizing
bind -r j resize-pane -D 5
bind -r k resize-pane -U 5
bind -r l resize-pane -R 5
bind -r h resize-pane -L 5

# fill pane to full screen
bind -r ENTER resize-pane -Z

bind S command-prompt -p "New session name:" "new-session -s '%%'"
bind W command-prompt -p "New window name:" "new-window -n '%%'"

# Initialize TMUX plugin manager
run '~/.config/tmux/plugins/tpm/tpm'

# Override catppuccin status bar with Shargeek theme (must be after TPM)
set -g status-style "bg=#1C1D1F"
set -g status-justify centre
set -g status-left-length 50
set -g status-right-length 80
set-option -g status-left "#[fg=#E8B830,bg=#1C1D1F,bold] #S "
set-option -g status-right "#{?SSH_CONNECTION,#[fg=#E8B830] 󰣀 #[fg=#8A8D93]#{=20:SSH_CONNECTION} ,}#[fg=#8A8D93]%Y-%m-%d #[fg=#E8E8EA]%H:%M:%S "
set -g pane-border-format " #{b:pane_current_path} #{?#{==:#{pane_current_command},ssh},󰣀 ,}#{@claude_status}"
